# ── Backend secrets (set these on Render) ─────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-another-long-random-string
JWT_EXP_HOURS=12

# Shared code required to register an admin account
ADMIN_REG_CODE=KWASU-ADMIN-2024

# MySQL connection (Railway / PlanetScale)
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/kwasu_complaints

# Comma-separated allowed frontend origins (your Vercel URL)
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Frontend (set in Vercel) ──────────────────────────────────────────
# VITE_API_URL=https://your-backend.onrender.com/api
